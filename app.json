{
  "expo": {
    "name": "SignalStack",
    "slug": "ai-subscriptions-widget",
    "version": "1.0.0",
    "newArchEnabled": false,
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "signalstack",
    "ios": {
      "bundleIdentifier": "com.michaelpotter.signalstack",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "output": "server"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-image",
      [
        "expo-widgets",
        {
          "groupIdentifier": "group.com.michaelpotter.signalstack",
          "widgets": [
            {
              "name": "SignalStackWidget",
              "displayName": "SignalStack",
              "description": "Track AI usage, rate limits, and spend from your iPhone Home Screen.",
              "supportedFamilies": [
                "systemSmall",
                "systemMedium"
              ],
              "contentMarginsDisabled": false,
              "ios": {
                "supportedFamilies": [
                  "systemSmall",
                  "systemMedium"
                ],
                "configuration": {
                  "title": "SignalStack",
                  "description": "Choose which widget view to pin.",
                  "parameters": {
                    "focus": {
                      "title": "View",
                      "type": "enum",
                      "default": "overview",
                      "values": [
                        {
                          "name": "Overview",
                          "value": "overview"
                        },
                        {
                          "name": "OpenAI",
                          "value": "openai"
                        },
                        {
                          "name": "Anthropic",
                          "value": "anthropic"
                        },
                        {
                          "name": "Kimi",
                          "value": "kimi"
                        }
                      ]
                    }
                  }
                }
              }
            }
          ]
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "ExpoWidgetsTarget",
                  "bundleIdentifier": "com.michaelpotter.signalstack.ExpoWidgetsTarget",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.michaelpotter.signalstack"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "2a6f227a-70dd-4702-8b59-281b30bf36d0"
      }
    }
  }
}
